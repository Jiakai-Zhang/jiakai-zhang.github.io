---
import Layout from '../layouts/Layout.astro';
import publications from '../data/publications.json';
import news from '../data/news.json';
import experience from '../data/experience.json';

function highlightSelf(authors: string, self: string): string {
  if (!self || !authors.includes(self)) return authors;
  const escaped = self.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
  return authors.replace(new RegExp(escaped + '\\*?', 'g'), (m) => `<span class="me">${m}</span>`);
}
---

<Layout title="Jiakai Zhang">

  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <div class="hero-layout">
        <div class="hero-text">
          <p class="hero-greeting">Hi, I'm</p>
          <div class="hero-name-row">
            <div class="hero-avatar">
              <img src="/photo.jpg" alt="Jiakai Zhang" />
            </div>
            <h1 class="hero-name">Jiakai Zhang</h1>
          </div>
          <p class="hero-role">Assistant Researcher · Co-founder @ Cellverse</p>
          <div class="hero-bio">
            <p>
              I'm an Assistant Researcher at the
              <a href="http://www.yu-jingyi.com/cv/" target="_blank">VRVC Lab</a>,
              <a href="https://www.shanghaitech.edu.cn/" target="_blank">ShanghaiTech University</a>,
              where I also received my Ph.D. under <a href="http://www.yu-jingyi.com/cv/" target="_blank">Prof. Jingyi Yu</a>.
              My research focuses on AI for structural biology — making Cryo-EM reconstruction
              faster, more accurate, and accessible through foundation models.
            </p>
            <p>
              Beyond the lab, I co-founded
              <a href="https://www.cellverse.tech" target="_blank"><strong>Cellverse (寰渺科技)</strong></a>
              to bring these tools to real-world drug discovery. I've also spent time at
              <strong>Meta Reality Labs</strong> working on neural rendering and AR/VR.
            </p>
          </div>
          <div class="hero-links">
            <a href="mailto:zhangjk@shanghaitech.edu.cn" class="hero-link">
              <i class="fas fa-envelope"></i> Email
            </a>
            <a href="https://github.com/Jiakai-Zhang" target="_blank" class="hero-link">
              <i class="fab fa-github"></i> GitHub
            </a>
            <a href="https://scholar.google.com/citations?user=PXHsLMcAAAAJ&hl=en" target="_blank" class="hero-link">
              <i class="fas fa-graduation-cap"></i> Scholar
            </a>
            <a href="https://www.linkedin.com/in/jiakai-zhang-38b8b4217/" target="_blank" class="hero-link">
              <i class="fab fa-linkedin"></i> LinkedIn
            </a>
          </div>
        </div>
        <div class="code-window">
          <div class="code-header">
            <span class="code-dot red"></span>
            <span class="code-dot yellow"></span>
            <span class="code-dot green"></span>
            <span class="code-title">jiakai.py</span>
          </div>
          <div class="code-body">
            <span class="code-line comment"># Ph.D. Candidate &amp; Founder</span>
            <span class="code-line"></span>
            <span class="code-line"><span class="kw">from</span> <span class="str">shanghaitech</span> <span class="kw">import</span> <span class="fn">VRVC_Lab</span></span>
            <span class="code-line"><span class="kw">from</span> <span class="str">cryoem</span> <span class="kw">import</span> <span class="fn">FoundationModels</span></span>
            <span class="code-line"><span class="kw">from</span> <span class="str">ai</span> <span class="kw">import</span> <span class="fn">GenerativeModels</span></span>
            <span class="code-line"><span class="kw">from</span> <span class="str">startup</span> <span class="kw">import</span> <span class="fn">Cellverse</span>  <span class="comment"># Co-founder</span></span>
            <span class="code-line"></span>
            <span class="code-line"><span class="kw">def</span> <span class="fn">main</span><span class="op">():</span></span>
            <span class="code-line">&nbsp;&nbsp;<span class="fn">research</span><span class="op">(</span><span class="str">"AI + Protein"</span><span class="op">)</span></span>
            <span class="code-line">&nbsp;&nbsp;<span class="fn">build</span><span class="op">(</span><span class="str">"Future of Biotech"</span><span class="op">)</span></span>
            <span class="code-line">&nbsp;&nbsp;<span class="kw">return</span> <span class="fn">impact</span><span class="op">(</span><span class="str">scale</span><span class="op">=</span><span class="str">"global"</span><span class="op">)</span><span class="cursor"></span></span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- News -->
  <section id="news">
    <div class="container">
      <h2 class="section-title">News</h2>
      <ul class="news-list">
        {news.map((item) => (
          <li class="news-item">
            <span class="news-date">{item.date}</span>
            <span class="news-content" set:html={item.content} />
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Research & Publications -->
  <section id="research">
    <div class="container">
      <h2 class="section-title">Research</h2>

      <!-- Filter tabs -->
      <div class="pub-filters">
        <button class="pub-filter active" data-filter="all">All</button>
        {publications.map((group) => (
          <button class="pub-filter" data-filter={group.category}>{group.category}</button>
        ))}
      </div>

      <!-- Publications -->
      <div class="pub-list">
        {publications.map((group) => (
          <div class="pub-group" data-group={group.category}>
            {group.papers.map((paper) => (
              <div class="pub-card">
                <div class="pub-main">
                  <p class="pub-title">
                    {paper.links.project
                      ? <a href={paper.links.project} target="_blank">{paper.title}</a>
                      : paper.title
                    }
                  </p>
                  <p class="pub-authors" set:html={highlightSelf(paper.authors, paper.self)} />
                  <p class="pub-venue">
                    {paper.venue}
                    {paper.highlight && <span class="pub-highlight">{paper.highlight}</span>}
                  </p>
                </div>
                {Object.keys(paper.links).length > 0 && (
                  <div class="pub-links">
                    {paper.links.project && (
                      <a href={paper.links.project} target="_blank">
                        <i class="fas fa-globe"></i> Project
                      </a>
                    )}
                    {paper.links.paper && (
                      <a href={paper.links.paper} target="_blank">
                        <i class="fas fa-file-pdf"></i> Paper
                      </a>
                    )}
                    {paper.links.code && (
                      <a href={paper.links.code} target="_blank">
                        <i class="fab fa-github"></i> Code
                      </a>
                    )}
                    {paper.links.dataset && (
                      <a href={paper.links.dataset} target="_blank">
                        <i class="fas fa-database"></i> Dataset
                      </a>
                    )}
                  </div>
                )}
              </div>
            ))}
          </div>
        ))}
      </div>

      <script>
        const filters = document.querySelectorAll<HTMLButtonElement>('.pub-filter');
        const groups  = document.querySelectorAll<HTMLElement>('.pub-group');

        filters.forEach(btn => {
          btn.addEventListener('click', () => {
            filters.forEach(b => b.classList.remove('active'));
            btn.classList.add('active');

            const target = btn.dataset.filter;
            groups.forEach(g => {
              g.style.display = (target === 'all' || g.dataset.group === target) ? 'flex' : 'none';
            });
          });
        });
      </script>
    </div>
  </section>

  <!-- Startup -->
  <section id="startup">
    <div class="container">
      <h2 class="section-title">Startup</h2>
      <div class="startup-card">
        <div class="startup-header">
          <h3>Cellverse <span class="startup-cn">寰渺科技</span></h3>
          <p class="startup-tag">AI · Protein · Drug Discovery</p>
        </div>
        <p>
          Cellverse is an AI biotech startup building protein-centric computational tools to
          accelerate structural biology and drug discovery. We develop foundation models trained
          on large-scale cryo-EM and structural data.
        </p>
        <a href="https://www.cellverse.tech" target="_blank" class="startup-btn">
          Visit Website <i class="fas fa-arrow-right"></i>
        </a>
      </div>
    </div>
  </section>

  <!-- Experience -->
  <section id="experience">
    <div class="container">
      <h2 class="section-title">Experience</h2>
      <div class="exp-list">
        {experience.map((exp) => (
          <div class="exp-item">
            <div class="exp-period">{exp.period}</div>
            <div class="exp-content">
              <p class="exp-title">{exp.title}</p>
              <p class="exp-org">
                {exp.company}{exp.location ? `, ${exp.location}` : ''}
              </p>
              <p class="exp-desc">{exp.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section id="contact">
    <div class="container">
      <h2 class="section-title">Contact</h2>
      <div class="contact-grid">
        <a href="mailto:jiakai0309@gmail.com" class="contact-item">
          <i class="fas fa-envelope"></i>
          <div>
            <p class="contact-label">Personal</p>
            <p class="contact-value">jiakai0309@gmail.com</p>
          </div>
        </a>
        <a href="mailto:zhangjk@shanghaitech.edu.cn" class="contact-item">
          <i class="fas fa-graduation-cap"></i>
          <div>
            <p class="contact-label">Academic</p>
            <p class="contact-value">zhangjk@shanghaitech.edu.cn</p>
          </div>
        </a>
        <a href="mailto:jiakai.zhang@cellverse.tech" class="contact-item">
          <i class="fas fa-briefcase"></i>
          <div>
            <p class="contact-label">Business</p>
            <p class="contact-value">jiakai.zhang@cellverse.tech</p>
          </div>
        </a>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* ── Hero ───────────────────────────────────────────────── */
  .hero {
    padding: 120px 24px 80px;
    min-height: 100vh;
    display: flex;
    align-items: center;
  }
  .hero-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: center;
  }
  .hero-name-row {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 10px;
  }
  .hero-avatar {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    overflow: hidden;
    border: 2px solid var(--border);
    flex-shrink: 0;
    box-shadow: var(--shadow);
  }
  .hero-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 40%;
  }

  .hero-greeting {
    font-size: 1rem;
    color: var(--accent);
    font-weight: 500;
    margin-bottom: 8px;
  }
  .hero-name {
    font-size: 2.75rem;
    font-weight: 700;
    color: var(--text);
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: 0;
  }
  .hero-role {
    font-size: 1rem;
    color: var(--text-m);
    margin-bottom: 20px;
  }
  .hero-bio {
    font-size: 0.95rem;
    color: var(--text-2);
    line-height: 1.75;
    max-width: 520px;
    margin-bottom: 28px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .hero-bio strong { color: var(--text); }
  .hero-links {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }
  .hero-link {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 8px 16px;
    border: 1px solid var(--border);
    border-radius: 7px;
    color: var(--text-2);
    font-size: 0.875rem;
    font-weight: 500;
    background: var(--bg-card);
    transition: all 0.2s;
  }
  .hero-link:hover {
    background: var(--accent);
    border-color: var(--accent);
    color: #fff;
  }
  /* Code window */
  .code-window {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
    box-shadow: var(--shadow);
    font-family: 'JetBrains Mono', 'Fira Code', 'Cascadia Code', monospace;
    font-size: 0.82rem;
    line-height: 1.7;
  }
  .code-header {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 9px 14px;
    background: var(--bg-card-h);
    border-bottom: 1px solid var(--border);
  }
  .code-dot { width: 11px; height: 11px; border-radius: 50%; }
  .code-dot.red    { background: #ff5f56; }
  .code-dot.yellow { background: #ffbd2e; }
  .code-dot.green  { background: #27c93f; }
  .code-title {
    margin-left: 8px;
    font-size: 0.75rem;
    color: var(--text-m);
  }
  .code-body { padding: 16px 20px; }
  .code-line { display: block; opacity: 0; animation: fadein 0.25s ease forwards; }
  .code-line:nth-child(1)  { animation-delay: 0.05s; }
  .code-line:nth-child(2)  { animation-delay: 0.10s; }
  .code-line:nth-child(3)  { animation-delay: 0.15s; }
  .code-line:nth-child(4)  { animation-delay: 0.20s; }
  .code-line:nth-child(5)  { animation-delay: 0.25s; }
  .code-line:nth-child(6)  { animation-delay: 0.30s; }
  .code-line:nth-child(7)  { animation-delay: 0.35s; }
  .code-line:nth-child(8)  { animation-delay: 0.40s; }
  .code-line:nth-child(9)  { animation-delay: 0.45s; }
  .code-line:nth-child(10) { animation-delay: 0.50s; }
  .code-line:nth-child(11) { animation-delay: 0.55s; }
  @keyframes fadein { to { opacity: 1; } }

  .kw  { color: #e06c75; }
  .str { color: #98c379; }
  .fn  { color: #61afef; }
  .op  { color: var(--text-m); }
  .comment { color: var(--text-m); font-style: italic; }
  [data-theme='light'] .kw  { color: #c0392b; }
  [data-theme='light'] .str { color: #27ae60; }
  [data-theme='light'] .fn  { color: #2980b9; }

  .cursor {
    display: inline-block;
    width: 2px;
    height: 1em;
    background: var(--accent);
    vertical-align: text-bottom;
    animation: blink 1s infinite;
  }
  @keyframes blink { 0%,49% { opacity:1; } 50%,100% { opacity:0; } }

  /* ── News ───────────────────────────────────────────────── */
  .news-list { list-style: none; display: flex; flex-direction: column; }
  .news-item {
    display: flex;
    gap: 24px;
    align-items: baseline;
    padding: 12px 0;
    border-bottom: 1px solid var(--border);
    font-size: 0.9rem;
  }
  .news-item:last-child { border-bottom: none; }
  .news-date {
    min-width: 68px;
    font-size: 0.775rem;
    font-weight: 500;
    color: var(--text-m);
    flex-shrink: 0;
  }
  .news-content { color: var(--text-2); }
  .news-content :global(strong) { color: var(--text); font-weight: 600; }

  /* ── Publications ───────────────────────────────────────── */
  .pub-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 24px;
  }
  .pub-filter {
    padding: 6px 14px;
    border: 1px solid var(--border);
    border-radius: 20px;
    background: transparent;
    color: var(--text-m);
    font-size: 0.825rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s;
    font-family: inherit;
  }
  .pub-filter:hover { border-color: var(--accent); color: var(--accent); }
  .pub-filter.active {
    background: var(--accent);
    border-color: var(--accent);
    color: #fff;
  }
  .pub-list { display: flex; flex-direction: column; gap: 12px; }
  .pub-group { display: flex; flex-direction: column; gap: 12px; }
  .pub-card {
    padding: 16px 18px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 10px;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .pub-card:hover {
    border-color: var(--accent);
    box-shadow: 0 0 0 1px var(--accent);
  }
  .pub-title {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 5px;
    line-height: 1.4;
  }
  .pub-title a { color: var(--text); }
  .pub-title a:hover { color: var(--accent); }
  .pub-authors {
    font-size: 0.825rem;
    color: var(--text-m);
    margin-bottom: 5px;
    line-height: 1.5;
  }
  .pub-authors :global(.me) {
    color: var(--text);
    font-weight: 600;
  }
  .pub-venue {
    font-size: 0.825rem;
    color: var(--accent);
    font-weight: 500;
    margin-bottom: 10px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .pub-highlight {
    font-size: 0.75rem;
    padding: 2px 8px;
    background: color-mix(in srgb, var(--accent-3) 15%, transparent);
    color: var(--accent-3);
    border-radius: 4px;
    font-weight: 600;
  }
  .pub-links {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }
  .pub-links a {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 4px 10px;
    font-size: 0.775rem;
    border: 1px solid var(--border);
    border-radius: 5px;
    color: var(--text-m);
    background: transparent;
    transition: all 0.2s;
  }
  .pub-links a:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  /* ── Startup ────────────────────────────────────────────── */
  .startup-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 28px 32px;
    max-width: 600px;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .startup-header { display: flex; flex-direction: column; gap: 4px; }
  .startup-header h3 {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--text);
  }
  .startup-cn {
    font-size: 1rem;
    color: var(--text-m);
    font-weight: 400;
    margin-left: 6px;
  }
  .startup-tag {
    font-size: 0.875rem;
    color: var(--accent-2);
    font-weight: 500;
  }
  .startup-card p {
    font-size: 0.95rem;
    color: var(--text-2);
    line-height: 1.7;
  }
  .startup-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 20px;
    background: var(--accent);
    color: #fff;
    border-radius: 7px;
    font-size: 0.875rem;
    font-weight: 600;
    align-self: flex-start;
    transition: opacity 0.2s;
  }
  .startup-btn:hover { opacity: 0.85; color: #fff; }

  /* ── Experience ─────────────────────────────────────────── */
  .exp-list { display: flex; flex-direction: column; gap: 0; }
  .exp-item {
    display: grid;
    grid-template-columns: 120px 1fr;
    gap: 24px;
    padding: 18px 0;
    border-bottom: 1px solid var(--border);
  }
  .exp-item:last-child { border-bottom: none; }
  .exp-period {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--text-m);
    padding-top: 2px;
    flex-shrink: 0;
  }
  .exp-title {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 3px;
  }
  .exp-org {
    font-size: 0.875rem;
    color: var(--accent);
    margin-bottom: 4px;
  }
  .exp-desc { font-size: 0.85rem; color: var(--text-m); }

  /* ── Contact ────────────────────────────────────────────── */
  .contact-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 12px;
  }
  .contact-item {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 16px 18px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 10px;
    color: var(--text-2);
    transition: border-color 0.2s;
  }
  .contact-item:hover { border-color: var(--accent); color: var(--text-2); }
  .contact-item i {
    font-size: 1.1rem;
    color: var(--accent);
    width: 20px;
    text-align: center;
    flex-shrink: 0;
  }
  .contact-label {
    font-size: 0.75rem;
    color: var(--text-m);
    font-weight: 500;
    margin-bottom: 2px;
  }
  .contact-value { font-size: 0.875rem; font-weight: 500; color: var(--text); }

  /* ── Mobile ─────────────────────────────────────────────── */
  @media (max-width: 640px) {
    .hero { padding: 88px 24px 60px; min-height: auto; }
    .hero-layout { grid-template-columns: 1fr; gap: 28px; }
    .hero-name { font-size: 2.1rem; }
    .code-window { font-size: 0.75rem; }

    .exp-item { grid-template-columns: 1fr; gap: 4px; }
    .exp-period { font-size: 0.75rem; }

    .startup-card { padding: 20px; }
  }
</style>

---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <style is:global>
    :root {
      --bg-deep: #0a0a14;
      --bg-main: #12122a;
      --bg-card: #1a1a2e;
      --bg-card-hover: #222240;
      --text-white: #ffffff;
      --text-gray: #e0e0e8;
      --text-muted: #8888a0;
      --accent-blue: #00d4ff;
      --accent-green: #00ff88;
      --accent-purple: #8b5cf6;
      --border-subtle: rgba(255,255,255,0.08);
    }
    
    * { margin: 0; padding: 0; box-sizing: border-box; }
    
    html { scroll-behavior: smooth; }
    
    body {
      font-family: 'Inter', -apple-system, sans-serif;
      background: var(--bg-deep);
      color: var(--text-gray);
      line-height: 1.6;
    }
    
    a { color: var(--accent-blue); text-decoration: none; transition: 0.2s; }
    a:hover { color: var(--accent-green); }
    
    .container { max-width: 1100px; margin: 0 auto; padding: 0 20px; }
    
    .navbar {
      position: fixed; top: 0; left: 0; right: 0;
      height: 56px;
      background: rgba(10,10,20,0.9);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border-subtle);
      z-index: 1000;
    }
    
    .navbar .container {
      display: flex; justify-content: space-between; align-items: center;
      height: 100%;
    }
    
    .nav-logo {
      font-family: 'JetBrains Mono', monospace;
      font-size: 1rem; font-weight: 600;
      color: var(--text-white);
    }
    
    .nav-links { display: flex; gap: 28px; list-style: none; }
    
    .nav-links a {
      color: var(--text-muted); font-weight: 500; font-size: 0.9rem;
      position: relative;
    }
    
    .nav-links a::after {
      content: ''; position: absolute; bottom: -4px; left: 0;
      width: 0; height: 2px; background: var(--accent-blue);
      transition: width 0.3s;
    }
    
    .nav-links a:hover { color: var(--text-white); }
    .nav-links a:hover::after { width: 100%; }
    
    section { padding: 50px 0; }
    section:nth-child(even) { background: var(--bg-main); }
    
    .section-title {
      font-size: 1.5rem; font-weight: 600;
      margin-bottom: 24px;
      display: flex; align-items: center; gap: 10px;
    }
    
    .section-title i { color: var(--accent-blue); }
    
    footer {
      background: var(--bg-deep);
      border-top: 1px solid var(--border-subtle);
      padding: 30px 0;
      text-align: center;
    }
    
    footer p { color: #555566; font-size: 0.85rem; }
    
    @media (max-width: 768px) {
      .navbar .container { flex-direction: column; height: auto; padding: 12px 20px; gap: 12px; }
      .nav-links { gap: 16px; }
    }
  </style>
</head>
<body>
  <slot />
</body>
</html>
